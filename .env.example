# ── NMNH Signal Bot — пример окружения ──
# Скопируй в .env и заполни. Файл .env в git НЕ коммитится.

# Telegram
BOT_TOKEN=your_bot_token_from_BotFather
# Telegram ID ментора: нужен боту И бэкенду (уведомления о заказах в маркете)
ADMIN_TG_ID=your_telegram_id_from_userinfobot

# База данных (канон — PostgreSQL; для локальной разработки можно SQLite)
# PostgreSQL: postgresql+psycopg://user:pass@localhost:5432/nmnh
# SQLite (dev): sqlite:///nmnh_dev.sqlite3
DATABASE_URL=sqlite:///nmnh_dev.sqlite3

# WEEX API (пока работаем на моках — можно оставить пустым)
# Когда появятся ключи и выставишь WEEX_USE_MOCK=false — будут реальные вызовы.
WEEX_USE_MOCK=true
WEEX_API_KEY=
WEEX_SECRET_KEY=
WEEX_PASSPHRASE=
WEEX_AFFILIATE_KEY=
WEEX_AFFILIATE_SECRET=
WEEX_AFFILIATE_PASSPHRASE=
# Закрытый аффилиат-эндпоинт баланса реферала (уточняется у партнёрского менеджера WEEX):
WEEX_AFFILIATE_BALANCE_PATH=/api/v2/rebate/affiliate/getChannelUserTradeAndAsset
WEEX_AFFILIATE_UID_PARAM=uid
WEEX_MIN_ORDER_USD=5

# Бэкенд (FastAPI)
JWT_SECRET=change-me-to-a-long-random-secret
ACCESS_TTL=900            # access-токен, сек (15 мин)
REFRESH_TTL=2592000       # refresh-токен, сек (30 дней)
AUTH_CODE_TTL=300         # TTL кода входа, сек
AUTH_MAX_ATTEMPTS=5       # попыток ввода кода
AUTH_EXPOSE_CODES=false   # dev: возвращать код в ответе request-code
MENTOR_PASSWORD=          # пароль входа ментора в веб-панель (MVP)
# Dev-вход без кода/пароля (кнопка-гаечный ключ во фронте). По умолчанию включён,
# когда WEEX_USE_MOCK=true. В проде (реальный WEEX) выключен; можно форсить:
DEV_LOGIN=                # true / false / пусто (=авто по WEEX_USE_MOCK)

# Безопасность (прод)
ALLOWED_ORIGINS=*               # CORS: домены фронта через запятую, напр. https://nmnh.io
RATE_LIMIT_MAX=10               # попыток на /api/auth/* за окно
RATE_LIMIT_WINDOW=900           # окно rate limit, сек (15 мин)

# Прочее
LOG_LEVEL=INFO
