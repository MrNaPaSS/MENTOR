# ── NMNH Signal Bot — пример окружения ──
# Скопируй в .env и заполни. Файл .env в git НЕ коммитится.

# Telegram
BOT_TOKEN=your_bot_token_from_BotFather
ADMIN_TG_ID=your_telegram_id_from_userinfobot

# База данных (канон — PostgreSQL; для локальной разработки можно SQLite)
# PostgreSQL: postgresql+psycopg://user:pass@localhost:5432/nmnh
# SQLite (dev): sqlite:///nmnh_dev.sqlite3
DATABASE_URL=sqlite:///nmnh_dev.sqlite3

# WEEX API (пока работаем на моках — можно оставить пустым)
# Когда появятся ключи и выставишь WEEX_USE_MOCK=false — будут реальные вызовы.
WEEX_USE_MOCK=true
WEEX_API_KEY=
WEEX_SECRET_KEY=
WEEX_PASSPHRASE=
WEEX_AFFILIATE_KEY=
WEEX_AFFILIATE_SECRET=
WEEX_AFFILIATE_PASSPHRASE=

# Бэкенд (FastAPI)
JWT_SECRET=change-me-to-a-long-random-secret
ACCESS_TTL=900            # access-токен, сек (15 мин)
REFRESH_TTL=2592000       # refresh-токен, сек (30 дней)
AUTH_CODE_TTL=300         # TTL кода входа, сек
AUTH_MAX_ATTEMPTS=5       # попыток ввода кода
AUTH_EXPOSE_CODES=false   # dev: возвращать код в ответе request-code
MENTOR_PASSWORD=          # пароль входа ментора в веб-панель (MVP)

# Прочее
LOG_LEVEL=INFO
